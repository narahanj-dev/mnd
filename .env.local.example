NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# npm run generate-security-keys 명령 결과를 입력합니다.
PII_ENCRYPTION_KEY=
PII_HASH_KEY=
PASSWORD_HISTORY_PEPPER=

# 초기 관리자 생성 시에만 사용합니다. 보안정책을 충족하는 값을 입력하세요.
INITIAL_ADMIN_ID=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=관리자
INITIAL_ADMIN_DEPARTMENT=대대본부

# 서버 강제 5분 세션 쿠키 서명키
SESSION_SIGNING_KEY=

# 로그인·관리자 작업 속도제한 식별자 해시 키
RATE_LIMIT_PEPPER=

# 관리자/부서관리자 TOTP MFA 강제. 운영환경에서는 true 권장
REQUIRE_ADMIN_MFA=true

# 운영 서비스의 고정 주소입니다. 로컬 개발은 http://localhost:3000
APP_ORIGIN=http://localhost:3000

# 자체 역방향 프록시를 운영하고 전달 헤더를 신뢰할 때만 true
TRUST_PROXY_HEADERS=false

# 로컬 테스트 데이터 생성 시에만 사용합니다. 운영환경에는 설정하지 마세요.
ALLOW_DEMO_SEED=false
# Supabase URL의 첫 번째 값(https://여기.supabase.co)과 정확히 같아야 합니다.
DEMO_SEED_ALLOWED_PROJECT_REF=
