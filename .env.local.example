NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# npm run generate-security-keys 명령 결과를 입력합니다.
PII_ENCRYPTION_KEY=
PII_HASH_KEY=
PASSWORD_HISTORY_PEPPER=

# 회원가입 신청 시 관리자에게 구두로 전달받은 코드를 서버에서만 검증합니다.
# NEXT_PUBLIC_ 접두사를 붙이지 마세요. 실제 코드는 GitHub에 올리지 말고 Vercel 환경변수에 설정하세요.
SIGNUP_INVITE_CODE=

# 초기 관리자 생성 시에만 사용합니다. 보안정책을 충족하는 값을 입력하세요.
INITIAL_ADMIN_ID=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=관리자
INITIAL_ADMIN_DEPARTMENT=대대본부

# 서버 강제 5분 세션 쿠키 서명키
SESSION_SIGNING_KEY=

# 로그인·가입신청·관리자 작업 속도제한 식별자 해시 키
RATE_LIMIT_PEPPER=

# 관리자/부서관리자 TOTP MFA 강제. 운영환경에서는 true 권장
REQUIRE_ADMIN_MFA=true
