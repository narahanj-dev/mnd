# npm run generate-security-keys 결과를 Vercel과 로컬 환경에 등록합니다.
# 기존 운영 프로젝트의 PII 관련 키는 새 값으로 교체하지 마세요.
PII_ENCRYPTION_KEY=
PII_HASH_KEY=
PASSWORD_HISTORY_PEPPER=
SESSION_SIGNING_KEY=
RATE_LIMIT_PEPPER=

# 서버 전용 값입니다. NEXT_PUBLIC_ 접두사를 사용하지 않습니다.
REQUIRE_ADMIN_MFA=true

# 운영 서비스의 고정 주소입니다. CSRF 출처 검증에 사용합니다.
APP_ORIGIN=https://YOUR_DOMAIN.example

# Vercel/Cloudflare/Fly 외 자체 역방향 프록시에서만 true로 설정합니다.
TRUST_PROXY_HEADERS=false
